# Data backend: "local" or "s3"
DATA_BACKEND=local

# Host path to the local data directory (mounted into the container as /data)
HOST_DATA_PATH=

# Path inside the container where data is mounted
LOCAL_DATA_ROOT=/data

# S3 settings (used when DATA_BACKEND=s3)
S3_BUCKET=nasa-radiant-data
AIA_ZARR_PREFIX=helioai-datasets/us-fdlx-ard/sdomlv2a/AIA.zarr
HMI_ZARR_PREFIX=helioai-datasets/us-fdlx-ard/sdomlv2a/HMI.zarr
